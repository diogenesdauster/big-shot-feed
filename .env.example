# ──────────────────────────────────────────────
# big-shot-feed — environment variables
# ──────────────────────────────────────────────

# PostgreSQL connection (Dokploy-postgres shared instance)
DATABASE_URL=postgresql://bigshot_feed:CHANGE_ME@localhost:5432/bigshot_feed?schema=public

# API server
PORT=3001
ADMIN_API_KEY=generate_a_long_random_string_here

# GitHub API (optional but recommended — raises rate limit 60/h → 5000/h)
GITHUB_TOKEN=

# Cron schedule (hourly by default)
CRON_SCHEDULE=0 * * * *

# Dev mode — skip external calls, use fixtures
DRY_RUN=false

# Log level
LOG_LEVEL=info
